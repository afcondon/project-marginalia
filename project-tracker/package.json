{
  "name": "project-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "spago build",
    "build:server": "spago build -p project-tracker-server",
    "build:frontend": "spago build -p project-tracker-frontend",
    "bundle:frontend": "spago bundle -p project-tracker-frontend",
    "bootstrap": "spago build && spago bundle -p project-tracker-frontend && spago bundle -p marginalia-capture",
    "build:capture": "spago build -p marginalia-capture",
    "bundle:capture": "spago bundle -p marginalia-capture",
    "serve:api": "node server/run.js",
    "serve:frontend": "npx http-server frontend/public -p 3100"
  },
  "dependencies": {
    "duckdb": "^1.4.4"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "http-server": "^14.1.1",
    "purescript": "0.15.15",
    "spago": "1.0.3"
  }
}
